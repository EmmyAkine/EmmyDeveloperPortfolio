<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Emmanuel Oyebamiji</title>
    <meta name="description" content="Portfolio of Emmanuel Oyebamiji, a Unity game developer and ASP.NET backend engineer." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Our custom CSS (the v0 design translated) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===================== NAVBAR ===================== -->
        <header class="site-nav" id="siteNav">
        <div class="nav-inner">

            <!-- Logo -->
                <a href="/" class="nav-logo">
                <span class="logo-icon">&lt;/&gt;</span>
            <span>EO<span class="text-primary">.dev</span></span>
            </a>

            <!-- Desktop links -->
                <ul class="nav-links">
                <li><a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a></li>
                <li><a href="@Url.Action("About", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">About</a></li>
                <li><a href="@Url.Action("Skills", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Skills" ? "active" : "")">Skills</a></li>
                <li><a href="@Url.Action("Projects", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Projects" ? "active" : "")">Projects</a></li>
                <li><a href="@Url.Action("Tax", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Tax" ? "active" : "")">Tax Calculator</a></li>
                <li><a href="@Url.Action("Contact", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact</a></li>
                <li><a href="@Url.Action("Gallery", "Home")">Gallery</a></li>
            </ul>

            <!-- Hire Me -->
            <a href="@Url.Action("Contact", "Home")" class="btn-hire d-none d-md-inline-flex">Hire Me</a>

            <!-- Mobile toggle -->
                <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
            <i class="bi bi-list" id="navIcon"></i>
        </button>
        </div>

        <!-- Mobile menu -->
            <div class="nav-mobile" id="navMobile">
                <ul>
                <li><a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a></li>
                <li><a href="@Url.Action("About", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">About</a></li>
                <li><a href="@Url.Action("Skills", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Skills" ? "active" : "")">Skills</a></li>
                <li><a href="@Url.Action("Projects", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Projects" ? "active" : "")">Projects</a></li>
                <li><a href="@Url.Action("Tax", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Tax" ? "active" : "")">Tax Calculator</a></li>
                <li><a href="@Url.Action("Contact", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact</a></li>
                <li><a href="@Url.Action("Contact", "Home")" class="btn-hire">Hire Me</a></li>
                <li><a href="@Url.Action("Gallery", "Home")">Gallery</a></li>
        </ul>
    </div>
    </header>

    <!-- ===================== PAGE CONTENT ===================== -->
        <div class="page-content">
    @RenderBody()
    </div>

    <!-- ===================== FOOTER ===================== -->
        <footer class="site-footer">
            <div class="footer-inner">
                <p class="footer-copy">
            &copy; @DateTime.Now.Year Emmanuel Oyebamiji. Built with ASP.NET Core MVC.
            </p>
                <div class="footer-social">
                    <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.07 11.07 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.05.78 2.12 0 1.53-.01 2.77-.01 3.15 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z" />
                </svg>
                </a>
                    <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z" />
                </svg>
                </a>
                    <a href="mailto:emmy@gmail.com" aria-label="Email" class="social-btn">
                <i class="bi bi-envelope"></i>
            </a>
        </div>
    </div>
    </footer>

    <!-- ===================== SCRIPTS ===================== -->
        <script>
            // Navbar scroll effect
            const nav = document.getElementById('siteNav');
            window.addEventListener('scroll', () => {
                nav.classList.toggle('scrolled', window.scrollY > 16);
        });

            // Mobile menu toggle
            const toggle = document.getElementById('navToggle');
            const menu   = document.getElementById('navMobile');
        const icon   = document.getElementById('navIcon');

            toggle.addEventListener('click', () => {
                const isOpen = menu.classList.toggle('open');
                toggle.setAttribute('aria-expanded', isOpen);
                icon.className = isOpen ? 'bi bi-x' : 'bi bi-list';
        });

            // Close mobile menu on link click
            menu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    menu.classList.remove('open');
                    icon.className = 'bi bi-list';
                    toggle.setAttribute('aria-expanded', false);
                });
        });
    </script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
