@model EmmyDeveloperPortfolio.Models.PortfolioModel

@{
    ViewData["Title"] = "Contact";
}

<section class="contact-section">
    <div style="max-width:1152px; margin:0 auto; padding: 5rem 1.5rem;">

        <!-- Section heading -->
        <div class="section-heading">
            <p class="eyebrow">05 — Contact</p>
            <h2>Let&apos;s build something</h2>
            <p>Have a game idea, a backend challenge, or a role in mind? Send a message and I&apos;ll get back to you.</p>
        </div>

        <div class="contact-grid">

            <!-- Info cards -->
            <div class="contact-info-cards">
                <div class="contact-info-card">
                    <span class="icon-badge"><i class="bi bi-envelope"></i></span>
                    <div>
                        <p class="label">Email</p>
                        <p class="value">@Model.Email</p>
                    </div>
                </div>
                <div class="contact-info-card">
                    <span class="icon-badge"><i class="bi bi-geo-alt"></i></span>
                    <div>
                        <p class="label">Location</p>
                        <p class="value">Lagos, Nigeria — Remote</p>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="contact-form-wrap">

                <!-- Success message (hidden until submit) -->
                <div class="contact-success" id="successMsg">
                    <span class="check-big"><i class="bi bi-check-circle-fill"></i></span>
                    <h3>Message sent!</h3>
                    <p>Thanks! I&apos;ll be in touch soon.</p>
                </div>

                <!-- The form -->
                <form id="contactForm" asp-action="Contact" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-row">
                        <div class="form-group">
                            <label for="senderName">Name</label>
                            <input type="text" id="senderName" name="senderName" required
                                   placeholder="Jane Doe" class="form-control-custom" />
                        </div>
                        <div class="form-group">
                            <label for="senderEmail">Email</label>
                            <input type="email" id="senderEmail" name="senderEmail" required
                                   placeholder="jane@example.com" class="form-control-custom" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" required
                                  placeholder="Tell me about your project..."
                                  class="form-control-custom"></textarea>
                    </div>

                    <button type="submit" class="btn-primary">
                        <i class="bi bi-send"></i> Send Message
                    </button>
                </form>

            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    // Show success state after form submit (client-side preview)
    document.getElementById('contactForm').addEventListener('submit', function (e) {
        e.preventDefault(); // Remove this line once you wire up a real POST handler
        this.style.display = 'none';
        document.getElementById('successMsg').style.display = 'flex';
    });
</script>
}
