@model EmmyDeveloperPortfolio.Models.PortfolioModel

@{
    ViewData["Title"] = "Projects";
}

<section class="projects-section">
    <div style="max-width:1152px; margin:0 auto; padding: 5rem 1.5rem;">

        <!-- Section heading -->
        <div class="section-heading">
            <p class="eyebrow">03 — Projects</p>
            <h2>Selected work</h2>
            <p>A mix of shipped games and production backend systems. Each project reflects a focus on craft, performance, and maintainability.</p>
        </div>

        <div class="projects-grid">

            @foreach (var project in Model.Projects)
            {
                <article class="project-card">

                    <!-- Image / placeholder -->
                    <div class="project-image">
                        @if (!string.IsNullOrEmpty(project.ImageUrl))
                        {
                            <img src="@project.ImageUrl" alt="@project.Title preview" />
                        }
                        else
                        {
                            <span>@project.Category</span>
                        }

                        @if (project.Featured)
                        {
                            <span class="featured-badge">Featured</span>
                        }
                    </div>

                    <!-- Body -->
                    <div class="project-body">
                        <p class="project-category">@project.Category</p>
                        <h3 class="project-title">@project.Title</h3>
                        <p class="project-desc">@project.Description</p>

                        <ul class="project-tags">
                            @foreach (var tag in project.Tags)
                            {
                                <li class="tag">@tag</li>
                            }
                        </ul>

                        <div class="project-links">
                            @if (!string.IsNullOrEmpty(project.GitHubUrl))
                            {
                                <a href="@project.GitHubUrl" target="_blank" rel="noopener noreferrer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.07 11.07 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.05.78 2.12 0 1.53-.01 2.77-.01 3.15 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"/>
                                    </svg>
                                    Code
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(project.LiveUrl))
                            {
                                <a href="@project.LiveUrl" target="_blank" rel="noopener noreferrer">
                                    <i class="bi bi-box-arrow-up-right"></i> Live Demo
                                </a>
                            }
                        </div>
                    </div>

                </article>
            }

        </div>
    </div>
</section>
