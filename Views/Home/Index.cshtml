            <a href="mailto:emmanueloyebamiji03@gmail.com" aria-label="Email" class="social-btn">
                <i class="bi bi-envelope"></i>
            </a>
        </div>

        <!-- Stat cards -->
        <div class="hero-stats">
            <div class="stat-card">
                <p class="stat-value">5+</p>
                <p class="stat-label">Years Building</p>
            </div>
            <div class="stat-card">
                <p class="stat-value">30+</p>
                <p class="stat-label">Projects Shipped</p>
            </div>
            <div class="stat-card">
                <p class="stat-value">Unity / C#</p>
                <p class="stat-label">Game Engine <i class="bi bi-controller text-primary"></i></p>
            </div>
            <div class="stat-card">
                <p class="stat-value">ASP.NET Core</p>
                <p class="stat-label">Backend <i class="bi bi-server text-primary"></i></p>
            </div>
