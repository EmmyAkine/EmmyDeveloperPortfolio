@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="hero-inner">

        <!-- Available badge -->
        <div class="hero-badge">
            <span class="dot"></span>
            Available for freelance &amp; full-time roles
        </div>

        <!-- Headline -->
        <h1>
            Emmanuel Oyebamiji
            <span class="subtitle">
                Unity Game Developer &amp; <span class="text-primary">ASP.NET</span> Engineer
            </span>
        </h1>

        <!-- Bio -->
        <p class="hero-bio">
            I craft immersive, performant games with Unity and engineer
            scalable, secure backends with ASP.NET Core. From gameplay systems
            to production APIs, I build experiences that feel great and run reliably.
        </p>

        <!-- CTA buttons -->
        <div class="hero-actions">
            <a href="@Url.Action("Projects", "Home")" class="btn-primary">
                View Projects <i class="bi bi-arrow-right"></i>
            </a>
            <a href="@Url.Action("Contact", "Home")" class="btn-outline">
                <i class="bi bi-envelope"></i> Get in Touch
            </a>
        </div>

        <!-- Social links -->
        <div class="hero-social">
            <a href="https://github.com/EmmyAkine" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-btn">
